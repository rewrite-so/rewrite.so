{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types/2023-07-01"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@rewrite/shared": ["../../packages/shared/src"],
      "@rewrite/shared/*": ["../../packages/shared/src/*"],
      "@rewrite/prompts": ["../../packages/prompts/src"],
      "@rewrite/prompts/*": ["../../packages/prompts/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist", ".wrangler"]
}
