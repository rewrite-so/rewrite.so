# Web 端 API 代理目标（server-side rewrites 用，客户端不可见）
# dev: http://localhost:8787   prod: https://api.rewrite.so
API_BASE_URL=http://localhost:8787

# 客户端 fetch 用相对路径（让 next rewrites 接管），保证 same-origin cookie
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_EXTENSION_INSTALL_URL=https://github.com/rewrite-so/rewrite.so/releases/latest
