# Web 端 API 代理目标（server-side rewrites 用，客户端不可见）
# dev: http://localhost:8787   prod: https://api.rewrite.so
API_BASE_URL=http://localhost:8787

# 客户端 fetch 用相对路径（让 next rewrites 接管），保证 same-origin cookie
NEXT_PUBLIC_API_BASE=
# Turnstile site key（仅匿名 /try 反滥用）。留空 = 前端不加载 widget。
# Dev 测试用 Cloudflare 官方 always-pass key：1x00000000000000000000BB
# 配套 API TURNSTILE_SECRET 用 1x0000000000000000000000000000000AA。详见 docs/turnstile-setup.md
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_EXTENSION_INSTALL_URL=https://chromewebstore.google.com/detail/gheiendipgcgiligfmbimbbffkkfiamk
