# =====================================================================
# rewrite.so 环境变量样例
# 复制为 .env.local（被 .gitignore），各 app 通过 wrangler/next 自取
# =====================================================================

# ------ 上游 LLM（OpenAI 兼容协议，无内置默认值，必填）------
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=

# ------ BYOK 加密主密钥（base64-encoded 32 字节随机数）------
# 生成命令：node -e "console.log(crypto.getRandomValues(new Uint8Array(32)).reduce((s,b)=>s+String.fromCharCode(b),''))" | base64
BYOK_MASTER_KEY=

# ------ Auth ------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://api.rewrite.so
# Web 前端 origin（Magic Link 邮件链接 host 替换为这个，让 cookie 落在 web origin）
# dev: http://localhost:3000   prod: https://rewrite.so
WEB_ORIGIN=https://rewrite.so

# ------ Email（Resend）------
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@rewrite.so

# ------ Creem 计费 ------
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_PRO_MONTHLY_PRODUCT_ID=
CREEM_PRO_YEARLY_PRODUCT_ID=

# ------ Cloudflare Turnstile（仅网页体验页）------
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# ------ Web 公开变量 ------
NEXT_PUBLIC_API_BASE=https://api.rewrite.so
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ------ Extension ------
VITE_API_BASE=https://api.rewrite.so
