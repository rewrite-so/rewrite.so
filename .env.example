# =====================================================================
# rewrite.so 环境变量样例
# 复制为 .env.local（被 .gitignore），各 app 通过 wrangler/next 自取
# =====================================================================

# ------ 上游 LLM（OpenAI 兼容协议，无内置默认值，必填）------
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=

# ------ BYOK 加密主密钥（base64-encoded 32 字节随机数）------
# 生成命令：node -e "console.log(crypto.getRandomValues(new Uint8Array(32)).reduce((s,b)=>s+String.fromCharCode(b),''))" | base64
BYOK_MASTER_KEY=

# ------ Auth ------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://api.rewrite.so
# Web 前端 origin（Magic Link verify 仍走 api origin；verify 后 302 回这个 origin）
# dev: http://localhost:3000   prod: https://rewrite.so
WEB_ORIGIN=https://rewrite.so

# ------ Email（Resend）------
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@rewrite.so

# ------ Creem 计费 ------
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_PRO_MONTHLY_PRODUCT_ID=
CREEM_PRO_YEARLY_PRODUCT_ID=

# ------ Cloudflare Turnstile（仅匿名 web /try 反滥用）------
# 不配置时服务端 fail-open（dev 友好；扩展 + 登录用户路径不受影响）。
# 配置步骤见 docs/turnstile-setup.md。
# Cloudflare 官方 dev 测试 keys（本地调 widget UI 不需要真账号）：
#   sitekey 1x00000000000000000000BB + secret 1x0000000000000000000000000000000AA  =  always pass
#   sitekey 2x00000000000000000000BB + secret 2x0000000000000000000000000000000AA  =  always fail
# Prod：从 Cloudflare Dashboard → Turnstile → Add Site（widget mode = Invisible）拿到。
TURNSTILE_SECRET=

# ------ Web 公开变量 ------
NEXT_PUBLIC_API_BASE=https://api.rewrite.so
# Turnstile site key（公开值，build time 烘焙进 web bundle）。
# 留空 = 前端不加载 widget，匿名请求不带 token；如果 TURNSTILE_SECRET 配了，匿名 /try 全 403
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_EXTENSION_INSTALL_URL=
# i18n: hreflang / sitemap 的绝对 URL 前缀（无尾部 /）
NEXT_PUBLIC_SITE_ORIGIN=https://rewrite.so

# ------ Extension install CTA / email links ------
EXTENSION_INSTALL_URL=https://github.com/rewrite-so/rewrite.so/releases/latest

# ------ i18n 翻译脚本（本地开发，CI 不需要）------
# scripts/i18n-translate.mjs 调 LLM 翻译新增 key 用；不进 wrangler secrets
ANTHROPIC_API_KEY=

# ------ Extension ------
VITE_API_BASE=https://api.rewrite.so
